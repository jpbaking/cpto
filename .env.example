# Copy this file to .env and fill in values for your setup:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# OPENVPN_CONFIG_DIR
#
# Path to a local directory containing your OpenVPN client files (e.g. .ovpn
# config, credential files). It is mounted read-only into the openvpn container
# and becomes the working directory for the openvpn process, so relative paths
# inside your config file (e.g. "auth-user-pass client.pass") resolve against
# this directory.
#
# If you pass all configuration entirely via OPENVPN_CMD_ARGS (no files needed),
# leave this as-is — the mount will just be empty and harmless.
# -----------------------------------------------------------------------------
OPENVPN_CONFIG_DIR="./.openvpn"

# -----------------------------------------------------------------------------
# OPENVPN_CMD_ARGS
#
# Arguments passed verbatim to: openvpn <OPENVPN_CMD_ARGS>
#
# Common options:
#   --config <file>           Path to .ovpn file (relative to OPENVPN_CONFIG_DIR)
#   --auth-user-pass <file>   File with username on line 1, password on line 2
#   --auth-nocache            Do not cache credentials in memory
#   --remote-random           Shuffle the remote list on each connect attempt
# -----------------------------------------------------------------------------
OPENVPN_CMD_ARGS="--config client.ovpn --auth-user-pass client.pass --auth-nocache --remote-random"

# -----------------------------------------------------------------------------
# HTTP_PROXY_PORT
#
# Host port that will accept HTTP proxy connections (forwarded to tinyproxy).
# Default is 3128, the conventional HTTP proxy port.
# -----------------------------------------------------------------------------
HTTP_PROXY_PORT="3128"

# -----------------------------------------------------------------------------
# SOCKS_PROXY_PORT
#
# Host port that will accept SOCKS4/SOCKS5 proxy connections (forwarded to srelay).
# Default is 1080, the conventional SOCKS proxy port.
# -----------------------------------------------------------------------------
SOCKS_PROXY_PORT="1080"
